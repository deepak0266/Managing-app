<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LifeOS" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background, animated icon, and animation duration. -->
        <item name="windowSplashScreenBackground">#121212</item>
        <!-- Use the default launcher icon for now, real app would use an animated vector -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.LifeOS</item>
    </style>
</resources>
